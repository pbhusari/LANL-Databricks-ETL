{
  "datasets": [
    {
      "name": "failed_auth_events",
      "displayName": "Failed Auth Events",
      "queryLines": [
        "SELECT\n",
        "  SUM(failed_auth) as failed_auth_events\n",
        "FROM\n",
        "  workspace.gold_lanl.hourly_security_dashboard"
      ]
    },
    {
      "name": "total_auth_events",
      "displayName": "Total Auth Events",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_auth) as total_auth_events\n",
        "FROM\n",
        "  workspace.gold_lanl.hourly_security_dashboard"
      ]
    },
    {
      "name": "compromised_events",
      "displayName": "Compromised Events",
      "queryLines": [
        "SELECT\n",
        "  SUM(compromised_auth) as compromised_events\n",
        "FROM\n",
        "  workspace.gold_lanl.hourly_security_dashboard"
      ]
    },
    {
      "name": "unique_users",
      "displayName": "Unique Users",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT src_user) as unique_users\n",
        "FROM\n",
        "  workspace.gold_lanl.user_daily_auth_summary"
      ]
    },
    {
      "name": "daily_auth_activity",
      "displayName": "Daily Auth Activity",
      "queryLines": [
        "SELECT\n",
        "  time_day,\n",
        "  SUM(total_auth) as total_auth,\n",
        "  SUM(failed_auth) as failed_auth,\n",
        "  SUM(compromised_auth) as compromised_auth\n",
        "FROM\n",
        "  workspace.gold_lanl.hourly_security_dashboard\n",
        "GROUP BY\n",
        "  time_day\n",
        "ORDER BY\n",
        "  time_day"
      ]
    },
    {
      "name": "top_compromised_users",
      "displayName": "Top Compromised Users",
      "queryLines": [
        "SELECT\n",
        "  src_user,\n",
        "  src_domain,\n",
        "  SUM(compromised_events) as total_compromised,\n",
        "  SUM(total_auth_events) as total_auth,\n",
        "  ROUND(AVG(fail_rate), 4) as avg_fail_rate,\n",
        "  SUM(distinct_dest_computers) as total_dest_computers\n",
        "FROM\n",
        "  workspace.gold_lanl.user_daily_auth_summary\n",
        "WHERE\n",
        "  compromised_events > 0\n",
        "GROUP BY\n",
        "  src_user,\n",
        "  src_domain\n",
        "ORDER BY\n",
        "  total_compromised DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "hourly_auth_pattern",
      "displayName": "Hourly Auth Pattern",
      "queryLines": [
        "SELECT\n",
        "  time_hour,\n",
        "  AVG(total_auth) as avg_auth,\n",
        "  AVG(failed_auth) as avg_failed\n",
        "FROM\n",
        "  workspace.gold_lanl.hourly_security_dashboard\n",
        "GROUP BY\n",
        "  time_hour\n",
        "ORDER BY\n",
        "  time_hour"
      ]
    },
    {
      "name": "top_computers_traffic",
      "displayName": "Top 10 Computers by Traffic",
      "queryLines": [
        "SELECT\n",
        "  source_computer,\n",
        "  SUM(total_bytes) as total_bytes\n",
        "FROM\n",
        "  workspace.gold_lanl.computer_daily_network_profile\n",
        "GROUP BY\n",
        "  source_computer\n",
        "ORDER BY\n",
        "  total_bytes DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "daily_network_volume",
      "displayName": "Daily Network Volume",
      "queryLines": [
        "SELECT\n",
        "  time_day,\n",
        "  SUM(total_flows) as total_flows,\n",
        "  SUM(total_dns_lookups) as total_dns_lookups\n",
        "FROM\n",
        "  workspace.gold_lanl.computer_daily_network_profile\n",
        "GROUP BY\n",
        "  time_day\n",
        "ORDER BY\n",
        "  time_day"
      ]
    }
  ],
